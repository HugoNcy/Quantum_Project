# Configuration de l'environnement pour le projet QRC
# Renommez ce fichier en .env et remplissez vos propres valeurs (ne jamais commiter .env).

# IBM Quantum API Token (nécessaire pour accéder aux vrais backends ou calibrer les modèles de bruit)
IBM_QUANTUM_TOKEN=votre_token_ibm_ici

# Paramètres de simulation
NUM_SHOTS=1024
LOG_LEVEL=INFO
